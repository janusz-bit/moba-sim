    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {},
    "use_new_terminal": true,
    "reveal": "always"
  },
  {
    "label": "nix build (Windows .exe)",
    "command": "nix",
    "args": ["build", ".#windows"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {},
    "use_new_terminal": true,
    "reveal": "always"
  },
  {
    "label": "nix build tests",
    "command": "nix",
    "args": ["build", ".#tests", "--out-link", "result-tests"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {},
    "use_new_terminal": true,
    "reveal": "always"
  },
  {
    "label": "nix flake check",
    "command": "nix",
    "args": ["flake", "check"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {},
    "use_new_terminal": true,
    "reveal": "always"
  },
  {
    "label": "regenerate compile_commands.json (Linux)",
    "command": "./build.sh",
    "args": [],
